{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "oc-claw",
  "version": "1.8.4",
  "identifier": "com.openclaw.ooclaw",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5222",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "mini",
        "title": "oc-claw Mini",
        "width": 60,
        "height": 45,
        "x": -9999,
        "y": -9999,
        "visible": false,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "url": "index.html#/mini"
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    },
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false
      }
    },
    "resources": {
      "../public/assets": "assets/",
      "../../extensions/cursor": "extensions/cursor/"
    }
  }
}
