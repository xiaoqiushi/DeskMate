              <span class="oc-time oc-monitor-delete-time"><1m</span>
              <button class="oc-monitor-delete-btn oc-monitor-delete-target" aria-label="${T.deleteSessionAria}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
              </button>
            </div>
          </div>
        </div>
        <div class="oc-item">
          <div class="oc-avatar"><span class="oc-pet-img oc-codex-sprite oc-codex-mambo"></span><div class="oc-dot" style="background:#f59e0b;"></div></div>
          <div class="oc-item-main"><span class="oc-title text-white">auth-fix</span><span class="oc-subtitle">${T.subtitleWaitingApproval}</span></div>
          <div class="oc-item-right"><span class="oc-badge" style="background:#3f211d;color:#e87a65;">Claude</span><span class="oc-time"><1m</span></div>
        </div>
        <div class="oc-item">
          <div class="oc-avatar"><span class="oc-pet-img oc-codex-sprite oc-codex-taffy"></span><div class="oc-dot" style="background:#94a3b8;"></div></div>
          <div class="oc-item-main"><span class="oc-title text-white">api-retry</span><span class="oc-subtitle">${T.subtitleIdle}</span></div>
          <div class="oc-item-right"><span class="oc-badge" style="background:#334155;color:#e2e8f0;">Feishu</span><span class="oc-time">18h</span></div>
        </div>`;
    content.innerHTML = `
      <div class="oc-step oc-details-list" data-s="1">${monitorRows}
      </div>`;

    await wait(600);
    mascot.style.opacity = '0';
    notch.classList.add('oc-notch-open');
    const listStep = content.querySelector('[data-s="1"]');
    const renameRow = content.querySelector('.oc-monitor-rename-row');
    const renameTitle = content.querySelector('.oc-monitor-rename-title');
    const renameInput = content.querySelector('.oc-monitor-rename-input');
    const renameSubtitle = content.querySelector('.oc-monitor-rename-subtitle');
    const deleteBtn = content.querySelector('.oc-monitor-delete-target');
    const deleteRow = content.querySelector('.oc-monitor-delete-row');

    await wait(200);
    if (listStep) showStep(listStep);

    await wait(420);
    cursor.style.top = '20%';
    cursor.style.left = '34%';
    cursor.style.opacity = '1';
    renameRow?.classList.add('oc-monitor-hover');

    await wait(260);
    renameRow?.classList.add('oc-monitor-editing');
    if (renameInput) renameInput.value = initialRenameTitle;
    for (let i = 1; i <= renamedTitle.length; i++) {
      await wait(28);
      if (renameInput) renameInput.value = renamedTitle.slice(0, i);
    }
    await wait(80);
    if (renameTitle) renameTitle.textContent = renamedTitle;
    if (renameSubtitle) renameSubtitle.textContent = T.subtitleTitleUpdated;
    renameRow?.classList.remove('oc-monitor-editing');
    renameRow?.classList.add('oc-monitor-renamed');

    await wait(360);
    cursor.style.top = '35%';
    cursor.style.left = '84%';
    deleteRow?.classList.add('oc-monitor-hover');

    await wait(320);
    deleteRow?.classList.add('oc-monitor-delete-armed');
    deleteBtn?.classList.add('oc-monitor-delete-clicked');

    await wait(140);
    deleteRow?.classList.add('oc-item-deleting');
    cursor.style.opacity = '0';

    await wait(360);
    deleteRow?.remove();

    await wait(950);
  }

  function setActiveActionButton(target) {
    document.querySelectorAll('.oc-action-btn').forEach((btn) => {
      btn.style.setProperty('--progress', '0');
      btn.classList.toggle('oc-action-active', btn.dataset.target === target);
    });
  }

  function animateButtonProgress(target, duration, runId) {
    const activeBtn = document.querySelector(`.oc-action-btn[data-target="${target}"]`);
    if (!activeBtn) return;
    const startedAt = performance.now();
    const tick = (now) => {
      if (runId !== carouselRun) return;
      const progress = Math.min((now - startedAt) / duration, 1);
      activeBtn.style.setProperty('--progress', String(progress));
      if (progress < 1) {
        progressFrame = requestAnimationFrame(tick);
      }
    };
    progressFrame = requestAnimationFrame(tick);
  }

  const handlers = {
    companion: playCompanion,
    jump: playJump,
    approve: playApprove,
    details: playDetails,
    monitor: playMonitor,
  };

  function runMode(target) {
    const handler = handlers[target];
    const duration = MODE_DURATION[target];
    if (!handler || !duration) return;
    carouselRun += 1;
    const runId = carouselRun;
    handler();
    setActiveActionButton(target);
    animateButtonProgress(target, duration, runId);
    const idx = MODE_ORDER.indexOf(target);
    const nextTarget = MODE_ORDER[(idx + 1) % MODE_ORDER.length];
    const t = setTimeout(() => {
      if (runId !== carouselRun) return;
      runMode(nextTarget);
    }, duration);
    timers.push(t);
  }

  document.querySelectorAll('.oc-action-btn').forEach((btn) => {
    const clone = btn.cloneNode(true);
    btn.parentNode.replaceChild(clone, btn);
    clone.addEventListener('click', () => {
      const target = clone.dataset.target;
      if (target) runMode(target);
    });
  });

  runMode('companion');
}

setupMockup();
document.addEventListener('astro:page-load', setupMockup);
</script>
