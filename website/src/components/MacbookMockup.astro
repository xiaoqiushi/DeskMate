<script define:vars={{ mockupI18n }}>
function setupMockup() {
  const T = mockupI18n;
  const content = document.getElementById('oc-content');
  const cursor = document.getElementById('oc-cursor');
  const ccTerminal = document.getElementById('cc-terminal');
  const mascot = document.getElementById('oc-mascot');
  const notchWrap = document.getElementById('oc-notch-wrap');
  const notch = document.getElementById('oc-notch');
  const screen = document.getElementById('v6-screen');
  const mascotImg = document.querySelector('.oc-mascot-img');
  const mascotDot = document.getElementById('oc-mascot-dot');
  const topbarLeft = document.querySelector('.oc-topbar-l');
  const topbarRight = document.querySelector('.oc-topbar-r');
  let timers = [];
  let progressFrame = 0;
  let carouselRun = 0;
  const MODE_ORDER = ['companion', 'jump', 'approve', 'details', 'monitor'];
  const MODE_DURATION = {
    companion: 3900,
    jump: 4600,
    approve: 2800,
    details: 3400,
    monitor: 4300,
  };
  const defaultTopbarLeft = topbarLeft ? topbarLeft.innerHTML : '';
  const defaultTopbarRight = topbarRight ? topbarRight.innerHTML : '';
  const detailTopbarLeft = `
    <div class="oc-topbar-back"><span class="oc-topbar-back-arrow">&lsaquo;</span><span>${T.topbarBack}</span></div>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="oc-icon"><path d="M10.268 21a2 2 0 0 0 3.464 0"/><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326"/></svg>
  `;

  function setDetailsHeight() {
    if (!screen || !notch) return;
    const { height } = screen.getBoundingClientRect();
    notch.style.setProperty('--details-height', `${Math.round(height * 0.75)}px`);
  }

  function setDetailsLayout(enabled) {
    if (!notch) return;
    if (enabled) {
      setDetailsHeight();
      notch.classList.add('oc-notch-details');
      return;
    }
    notch.classList.remove('oc-notch-details');
  }

  function setTopbar(mode) {
    if (!topbarLeft || !topbarRight) return;
    if (mode === 'details') {
      topbarLeft.innerHTML = detailTopbarLeft;
      topbarRight.innerHTML = defaultTopbarRight;
      return;
    }
    topbarLeft.innerHTML = defaultTopbarLeft;
    topbarRight.innerHTML = defaultTopbarRight;
  }

  function clearTimers() {
    timers.forEach(t => clearTimeout(t));
    timers = [];
    if (progressFrame) cancelAnimationFrame(progressFrame);
    progressFrame = 0;
    cursor.style.opacity = '0';
    ccTerminal.classList.remove('cc-visible');
    ccTerminal.style.left = '';
    ccTerminal.style.transform = '';
    const companionPet = document.getElementById('oc-companion-pet');
    if (companionPet) companionPet.style.display = 'none';
    const ccComp = document.getElementById('cc-companion-terminal');
    if (ccComp) { ccComp.classList.remove('cc-visible'); ccComp.style.display = 'none'; }
  }

  function wait(ms) {
    return new Promise(r => { const t = setTimeout(r, ms); timers.push(t); });
  }

  function showStep(el) { el.classList.add('oc-visible'); }

  function setMascotMode(mode) {
    if (!mascotImg || !mascotDot) return;
    const isSleep = mode === 'sleep';
    // The persistent mascot is now a codex sprite (a <span> with a
    // background-image), so swapping `src` would be a no-op. Only the
    // status dot needs to flip between working/idle colours.
    if (mascotImg.tagName === 'IMG') {
      mascotImg.src = isSleep
        ? '/images/pets/furina_sleeping.gif'
        : '/images/pets/furina_working.gif';
    }
    mascotDot.style.background = isSleep ? '#94a3b8' : '#2ecc71';
  }

