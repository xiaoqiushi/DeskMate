---
import { type Lang } from '../i18n/index';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
---

<nav>
  <a href={`/${lang}/`} class="logo">
    <img src="/app-icon.png" alt="DeskMate" class="logo-icon" />
    <span class="logo-label">DeskMate</span>
  </a>
  <div class="nav-right">
    <a href="https://github.com/xiaoqiushi/DeskMate" class="nav-link">GitHub</a>
  </div>
</nav>

<style>
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
</style>
