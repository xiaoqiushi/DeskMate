---
import type { Lang } from '../i18n/index';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

const { title, description = 'A desktop pet that monitors your AI coding agents in real time.', lang = 'en' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/app-icon.png', Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'DeskMate',
  description,
  url: canonicalURL.href,
  image: ogImage.href,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Windows',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Person', name: 'xiaoqiushi', url: 'https://github.com/xiaoqiushi' },
  license: 'https://opensource.org/licenses/MIT',
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0f1014" />

    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&family=Manrope:wght@700;800&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <div class="container">
      <slot />
    </div>
    <Analytics />
  </body>
</html>
